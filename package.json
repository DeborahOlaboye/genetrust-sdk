{
  "name": "genetrust-sdk",
  "version": "1.0.0",
  "description": "SDK for interacting with the GeneTrust privacy-preserving genetic data marketplace on Stacks/Bitcoin",
  "type": "module",
  "main": "./src/index.js",
  "exports": {
    ".": {
      "import": "./src/index.js"
    },
    "./browser": {
      "import": "./src/browser.js"
    },
    "./contracts": {
      "import": "./src/contracts/index.js"
    },
    "./storage": {
      "import": "./src/storage/index.js"
    },
    "./zk-proofs": {
      "import": "./src/zk-proofs/index.js"
    },
    "./utils": {
      "import": "./src/utils/index.js"
    },
    "./config": {
      "import": "./src/config/phase2-config.js"
    }
  },
  "keywords": [
    "blockchain",
    "stacks",
    "bitcoin",
    "genetics",
    "genomics",
    "zero-knowledge",
    "zk-proofs",
    "ipfs",
    "privacy",
    "marketplace",
    "decentralized",
    "web3"
  ],
  "author": "Deborah Olaboye <deborah@genetrust.org>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/DeborahOlaboye/genetrust-sdk.git"
  },
  "bugs": {
    "url": "https://github.com/DeborahOlaboye/genetrust-sdk/issues"
  },
  "homepage": "https://github.com/DeborahOlaboye/genetrust-sdk#readme",
  "scripts": {
    "test": "node --experimental-vm-modules tests/exports.test.js && node --experimental-vm-modules tests/config.test.js && node --experimental-vm-modules tests/crypto.test.js && node --experimental-vm-modules tests/zk-proofs.test.js && node --experimental-vm-modules tests/formatter.test.js && node --experimental-vm-modules tests/contracts.test.js && node --experimental-vm-modules tests/performance.test.js",
    "test:exports": "node --experimental-vm-modules tests/exports.test.js",
    "test:config": "node --experimental-vm-modules tests/config.test.js",
    "test:crypto": "node --experimental-vm-modules tests/crypto.test.js",
    "test:zk": "node --experimental-vm-modules tests/zk-proofs.test.js",
    "test:formatter": "node --experimental-vm-modules tests/formatter.test.js",
    "test:contracts": "node --experimental-vm-modules tests/contracts.test.js",
    "test:performance": "node --experimental-vm-modules tests/performance.test.js"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@stacks/connect": "^7.5.0",
    "@stacks/network": "^6.12.0",
    "@stacks/transactions": "^6.12.0",
    "buffer": "^6.0.3",
    "ipfs-http-client": "^60.0.1",
    "winston": "^3.11.0",
    "winston-daily-rotate-file": "^4.7.1"
  },
  "peerDependencies": {
    "node": ">=18.0.0"
  }
}
